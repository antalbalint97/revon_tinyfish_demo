NODE_ENV=development
PORT=8787
WEB_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=
DATABASE_URL=./data/revon-tinyfish-demo.sqlite
TINYFISH_API_KEY=
TINYFISH_ENABLE_LIVE_CALLS=false
TINYFISH_BASE_URL=https://agent.tinyfish.ai/v1/automation/run-sse
TINYFISH_ASYNC_URL=https://agent.tinyfish.ai/v1/automation/run-async
TINYFISH_RUNS_BATCH_URL=https://agent.tinyfish.ai/v1/runs/batch
TINYFISH_FORCE_MOCK=true
TINYFISH_ENABLE_MOCK_FALLBACK=true
TINYFISH_POLL_INTERVAL_MS=3000
TINYFISH_ASYNC_RUN_TIMEOUT_MS=300000
TINYFISH_INSPECTION_CONCURRENCY=2
TINYFISH_DISCOVERY_PROMPT_VARIANT=discovery_prompt_v1
TINYFISH_INSPECTION_DEPTH_LABEL=inspect_depth_homepage_contact_about_team
SCORER_VARIANT_LABEL=scorer_typescript_v1
EXPERIMENT_LABEL=
TELEMETRY_MAX_SESSIONS=200
MAX_EXPORT_MB=
REVON_IMPORT_URL=
REVON_API_TOKEN=
REVON_IMPORT_MODE=webhook
REVON_DRY_RUN=true

# Zoho CRM integration
# OAuth2 credentials from Zoho API Console (Self Client, offline access)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Data center base URLs — use .eu for EU data center, .com for US
ZOHO_ACCOUNTS_URL=https://accounts.zoho.eu
ZOHO_API_BASE_URL=https://www.zohoapis.eu/crm/v6
# Target CRM module (Leads or Contacts)
ZOHO_MODULE=Leads
# Set to false to enable live sync
ZOHO_DRY_RUN=true
